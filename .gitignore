# ===========================
# CASCADEX .gitignore
# ===========================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# Virtual environments
venv/
.venv/
env/
ENV/

# --- Node / Expo ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.expo/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
ios/
android/

# --- Environment ---
.env
.env.local
.env.*.local

# --- Data (large files) ---
apps/pipeline/data/*.xml
apps/pipeline/data/*.csv
apps/pipeline/data/*.json
!apps/pipeline/data/.gitkeep
!apps/pipeline/data/seed_drugs.json

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Docker ---
*.log

# --- Neo4j backups ---
packages/graph/backups/

# --- Build artifacts ---
*.tgz

# --- Bug Reports ---
bugreport-*
