# ===========================
# CASCADEX — Environment Variables
# ===========================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Neo4j AuraDB ---
# Get these from: https://console.neo4j.io (free tier)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-auradb-password

# --- Groq ---
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenFDA (no key needed, rate-limited) ---
FDA_API_BASE=https://api.fda.gov

# --- RxNorm ---
RXNORM_API_BASE=https://rxnav.nlm.nih.gov/REST

# --- KEGG ---
KEGG_API_BASE=https://rest.kegg.jp

# --- App ---
API_PORT=8000
ENVIRONMENT=development
API_SECRET_KEY=change-me-to-a-random-string

# --- Railway (for CI/CD deploy) ---
RAILWAY_TOKEN=

# --- Expo (for EAS builds) ---
EXPO_TOKEN=
